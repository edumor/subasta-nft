# ── AuctionNFT (initial active auction) ──────────────────────────────────────
# Address of the first AuctionNFT contract deployed on Sepolia.
# The admin can switch the active contract from the UI without changing this value.
NEXT_PUBLIC_AUCTION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── AuctionFactory ────────────────────────────────────────────────────────────
# Address of the AuctionFactory deployed on Sepolia.
# Used by the Admin Panel to deploy new auctions from the browser wallet.
NEXT_PUBLIC_FACTORY_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── WalletConnect ─────────────────────────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── RPC (optional but recommended) ───────────────────────────────────────────
# Use Alchemy or Infura for more reliable access to Sepolia.
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
