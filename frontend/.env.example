# Required: Address of the deployed AuctionNFT contract on Sepolia
NEXT_PUBLIC_AUCTION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Required: WalletConnect Project ID (get one free at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Optional: Alchemy or Infura RPC for Sepolia (improves reliability)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key
